generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ──────────────────────────────────────────────────────────────

model users {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  user_id              String?
  student_id           String?
  name                 String?
  email                String?                @unique
  user_email           String?                @unique
  phone                String?
  country_code         String?
  role_id              Int?
  user_designation_id  Int?
  centre_id            String?                @db.ObjectId
  added_under_centre   Int?
  username             String?
  password             String?
  verification_code    String?
  status               Int                    @default(0)
  device_id            String?
  course_id            String?                @db.ObjectId
  notification_token   String?
  profile_picture      String?
  image                String?
  academic_year        String?
  premium              Int                    @default(0)
  created_by           String?                @db.ObjectId
  updated_by           String?                @db.ObjectId
  deleted_by           String?                @db.ObjectId
  created_at           DateTime?
  updated_at           DateTime?
  deleted_at           DateTime?
  auth_audit_log       auth_audit_log[]
  auth_session         auth_session[]
  enrol                enrol[]
  notification_read    notification_read[]
  otp_challenge        otp_challenge[]
  password_reset_token password_reset_token[]

  @@index([deleted_at])
  @@index([role_id])
  @@index([phone])
  @@index([course_id])
  @@index([centre_id])
  @@index([added_under_centre])
}

model auth_session {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id        String    @db.ObjectId
  token_hash     String    @unique
  created_at     DateTime?
  updated_at     DateTime?
  expires_at     DateTime
  revoked_at     DateTime?
  revoked_reason String?
  ip_address     String?
  user_agent     String?
  users          users     @relation(fields: [user_id], references: [id])

  @@index([user_id, revoked_at])
  @@index([expires_at])
}

model password_reset_token {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id              String    @db.ObjectId
  token_hash           String    @unique
  created_at           DateTime?
  updated_at           DateTime?
  expires_at           DateTime
  used_at              DateTime?
  requested_ip         String?
  requested_user_agent String?
  users                users     @relation(fields: [user_id], references: [id])

  @@index([user_id, used_at])
  @@index([expires_at])
}

model otp_challenge {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id              String    @db.ObjectId
  purpose              String
  delivery_target      String?
  otp_hash             String
  created_at           DateTime?
  updated_at           DateTime?
  expires_at           DateTime
  used_at              DateTime?
  attempt_count        Int       @default(0)
  max_attempts         Int       @default(5)
  requested_ip         String?
  requested_user_agent String?
  users                users     @relation(fields: [user_id], references: [id])

  @@index([user_id, purpose, used_at])
  @@index([expires_at])
}

model auth_audit_log {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String?   @db.ObjectId
  event      String
  identifier String?
  success    Int       @default(0)
  ip_address String?
  user_agent String?
  details    String?
  created_at DateTime?
  users      users?    @relation(fields: [user_id], references: [id])

  @@index([event, created_at])
  @@index([user_id])
  @@index([created_at])
}

// ─── Roles & Permissions ─────────────────────────────────────────────────────

model role {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  date_added    DateTime?
  last_modified DateTime?
  created_at    DateTime?
  updated_at    DateTime?
  deleted_at    DateTime?

  @@index([deleted_at])
}

model permission {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  title    String?
  slug     String?
  datetime DateTime?

  @@index([slug])
}

model permission_relationship {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  permission_id String    @db.ObjectId
  role_id       String    @db.ObjectId
  master        Int       @default(0)
  read          Int       @default(0)
  write         Int       @default(0)
  delete        Int       @default(0)
  datetime      DateTime?

  @@index([role_id])
  @@index([permission_id])
}

// ─── Centres & Wallet ──────────────────────────────────────────────────────────

model centres {
  id                          String    @id @default(auto()) @map("_id") @db.ObjectId
  centre_id                   Int?
  centre_name                 String
  country_id                  Int?
  state_id                    Int?
  district_id                 Int?
  address                     String?
  contact_person              String?
  contact_person_designation  String?
  country_code                String?
  phone                       String?
  whatsapp                    String?
  secondary_phone             String?
  email                       String?
  registraion_certificate     String?
  affiliation_document        String?
  wallet_balance              Float     @default(0)
  date_of_registration        DateTime?
  date_of_expiry              DateTime?
  created_by                  String?   @db.ObjectId
  updated_by                  String?   @db.ObjectId
  deleted_by                  String?   @db.ObjectId
  created_at                  DateTime?
  updated_at                  DateTime?
  deleted_at                  DateTime?

  @@index([centre_id])
  @@index([country_code, phone])
  @@index([email])
  @@index([deleted_at])
}

model wallet_transactions {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  centre_id        String    @db.ObjectId
  transaction_type String    @default("credit")
  amount           Float     @default(0)
  remarks          String?
  reference_id     String?
  created_by       String?   @db.ObjectId
  updated_by       String?   @db.ObjectId
  deleted_by       String?   @db.ObjectId
  created_at       DateTime?
  updated_at       DateTime?
  deleted_at       DateTime?

  @@index([centre_id])
  @@index([transaction_type])
  @@index([deleted_at])
}

model centre_fundrequests {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  centre_id           String    @db.ObjectId
  user_id             String    @db.ObjectId
  amount              Float     @default(0)
  date                DateTime?
  transaction_receipt  String?
  description         String?
  attachment_file     String?
  status              String    @default("pending")
  created_by          String?   @db.ObjectId
  updated_by          String?   @db.ObjectId
  deleted_by          String?   @db.ObjectId
  created_at          DateTime?
  updated_at          DateTime?
  deleted_at          DateTime?

  @@index([centre_id])
  @@index([status])
  @@index([deleted_at])
}

model centre_course_plans {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  centre_id       String    @db.ObjectId
  course_id       String    @db.ObjectId
  assigned_amount Float     @default(0)
  start_date      DateTime?
  end_date        DateTime?
  created_by      String?   @db.ObjectId
  updated_by      String?   @db.ObjectId
  deleted_by      String?   @db.ObjectId
  created_at      DateTime?
  updated_at      DateTime?
  deleted_at      DateTime?

  @@index([centre_id, course_id])
  @@index([deleted_at])
}

// ─── Applications ──────────────────────────────────────────────────────────────

model applications {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  application_id        String?
  name                  String
  country_code          String?
  phone                 String?
  email                 String?
  user_email            String?
  username              String?
  password              String?
  image                 String?
  status                String?   @default("pending")
  is_converted          Int       @default(0)
  pipeline              String?
  pipeline_user         String?   @db.ObjectId
  course_id             String?   @db.ObjectId
  batch_id              String?   @db.ObjectId
  enrollment_date       DateTime?
  enrollment_status     String?
  mode_of_study         String?
  preferred_language    String?
  date_of_birth         DateTime?
  age                   Int?
  gender                String?
  nationality           String?
  marital_status        String?
  aadhar_no             String?
  passport_no           String?
  whatsapp_no           String?
  second_code           String?
  second_phone          String?
  country_id            Int?
  district              String?
  state                 String?
  address               String?
  native_address        String?
  father_name           String?
  mother_name           String?
  guardian_name          String?
  emergency_name        String?
  emergency_phone       String?
  emergency_relation    String?
  learning_disabilities String?
  accessibility_needs   String?
  marketing_source      String?
  added_under_centre    Int?
  created_by            String?   @db.ObjectId
  updated_by            String?   @db.ObjectId
  deleted_by            String?   @db.ObjectId
  created_at            DateTime?
  updated_at            DateTime?
  deleted_at            DateTime?

  @@index([status])
  @@index([is_converted])
  @@index([course_id])
  @@index([pipeline_user])
  @@index([added_under_centre])
  @@index([created_by])
  @@index([deleted_at])
  @@index([email, user_email])
}

// ─── Qualifications & Documents ────────────────────────────────────────────────

model qualification {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id             String    @db.ObjectId
  qualification       String?
  institution         String?
  year_of_passing     String?
  percentage_or_grade String?
  created_by          String?   @db.ObjectId
  updated_by          String?   @db.ObjectId
  deleted_by          String?   @db.ObjectId
  created_at          DateTime?
  updated_at          DateTime?
  deleted_at          DateTime?

  @@index([user_id])
  @@index([deleted_at])
}

model student_document {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  student_id String    @db.ObjectId
  label      String?
  file       String?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([student_id])
  @@index([deleted_at])
}

// ─── Resources (Folders & Files) ───────────────────────────────────────────────

model folder {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  parent_id  String?   @db.ObjectId
  centre_id  String?   @db.ObjectId
  name       String
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([parent_id])
  @@index([centre_id])
  @@index([deleted_at])
}

model file {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  folder_id  String?   @db.ObjectId
  centre_id  String?   @db.ObjectId
  name       String
  type       String?
  size       Int?
  path       String?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([folder_id])
  @@index([centre_id])
  @@index([deleted_at])
}

// ─── Settings ──────────────────────────────────────────────────────────────────

model settings {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  key        String    @unique
  value      String?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([deleted_at])
}

model frontend_settings {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  key        String    @unique
  value      String?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([deleted_at])
}

model app_version {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  app_version     String?
  app_version_ios String?
  created_by      String?   @db.ObjectId
  updated_by      String?   @db.ObjectId
  deleted_by      String?   @db.ObjectId
  created_at      DateTime?
  updated_at      DateTime?
  deleted_at      DateTime?

  @@index([deleted_at])
}

// ─── Categories & Courses ──────────────────────────────────────────────────────

model category {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  code               String?
  name               String?
  parent             Int?
  slug               String?
  description        String?
  short_description  String?
  video_type         String?
  video_url          String?
  font_awesome_class String?
  thumbnail          String?
  category_icon      String?
  status             String?
  created_by         String?   @db.ObjectId
  updated_by         String?   @db.ObjectId
  deleted_by         String?   @db.ObjectId
  created_at         DateTime?
  updated_at         DateTime?
  deleted_at         DateTime?

  @@index([deleted_at])
}

model course {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  category_id    String?   @db.ObjectId
  title          String
  short_name     String?
  label          String?
  status         String?
  price          Float?
  sale_price     Float?
  total_amount   Float?
  description    String?
  duration       String?
  thumbnail      String?
  course_icon    String?
  features       String?
  is_free_course Int       @default(0)
  created_by     String?   @db.ObjectId
  updated_by     String?   @db.ObjectId
  deleted_by     String?   @db.ObjectId
  created_at     DateTime?
  updated_at     DateTime?
  deleted_at     DateTime?

  @@index([category_id])
  @@index([deleted_at])
}

model course_package {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String?
  description  String?
  type         Int?
  category_id  String?   @db.ObjectId
  course_id    String?   @db.ObjectId
  amount       Float?
  discount     Float?
  is_free      Int?
  package_type String?
  remarks      String?
  offline      Int?
  start_date   DateTime?
  end_date     DateTime?
  duration     Int?
  created_by   String?   @db.ObjectId
  updated_by   String?   @db.ObjectId
  deleted_by   String?   @db.ObjectId
  created_at   DateTime?
  updated_at   DateTime?
  deleted_at   DateTime?

  @@index([course_id])
  @@index([deleted_at])
  @@index([start_date, end_date])
  @@map("package")
}

model subject_package {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  package_id String    @db.ObjectId
  subject_id String?   @db.ObjectId
  amount     Float?
  discount   Float?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([package_id])
  @@index([deleted_at])
}

model package_features {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  package_id    String    @db.ObjectId
  title         String?
  value_type    String?
  value         String?
  listing_order Int?
  created_on    DateTime?
  updated_on    DateTime?

  @@index([package_id])
}

model coupon_code {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  code          String
  package_id    String?   @db.ObjectId
  user_id       String?   @db.ObjectId
  discount_perc Float     @default(0)
  total_no      Int       @default(0)
  per_user_no   Int       @default(0)
  validity      Int       @default(1)
  start_date    DateTime?
  end_date      DateTime?
  created_by    String?   @db.ObjectId
  updated_by    String?   @db.ObjectId
  deleted_by    String?   @db.ObjectId
  created_at    DateTime?
  updated_at    DateTime?
  deleted_at    DateTime?

  @@index([code])
  @@index([package_id, user_id])
  @@index([validity, start_date, end_date])
  @@index([deleted_at])
}

model create_order {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  order_id       String    @unique
  amount         Float     @default(0)
  user_id        String    @db.ObjectId
  course_id      String    @db.ObjectId
  order_status   String    @default("pending")
  notes          String?
  payment_id_raz String?
  datetime       DateTime?
  created_by     String?   @db.ObjectId
  updated_by     String?   @db.ObjectId
  deleted_by     String?   @db.ObjectId
  created_at     DateTime?
  updated_at     DateTime?
  deleted_at     DateTime?

  @@index([user_id, course_id])
  @@index([order_status])
  @@index([payment_id_raz])
  @@index([deleted_at])
}

// ─── Content: Subjects, Lessons, Files ─────────────────────────────────────────

model subject {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  course_id         String    @db.ObjectId
  master_subject_id String?   @db.ObjectId
  title             String
  description       String?
  thumbnail         String?
  order             Int?
  created_by        String?   @db.ObjectId
  updated_by        String?   @db.ObjectId
  deleted_by        String?   @db.ObjectId
  created_at        DateTime?
  updated_at        DateTime?
  deleted_at        DateTime?

  @@index([course_id])
  @@index([master_subject_id])
  @@index([deleted_at])
}

model lesson {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  course_id  String    @db.ObjectId
  subject_id String    @db.ObjectId
  title      String
  summary    String?
  free       String?
  thumbnail  String?
  order      Int?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([course_id])
  @@index([subject_id])
  @@index([deleted_at])
}

model lesson_files {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  lesson_id       String    @db.ObjectId
  parent_file_id  String?   @db.ObjectId
  sub_title       String?
  title           String?
  summary         String?
  duration        String?
  lesson_provider String?
  video_type      String?
  video_url       String?
  download_url    String?
  lesson_type     String?
  attachment_type String?
  attachment      String?
  audio_file      String?
  thumbnail       String?
  free            String?
  order           Int?
  created_by      String?   @db.ObjectId
  updated_by      String?   @db.ObjectId
  deleted_by      String?   @db.ObjectId
  created_at      DateTime?
  updated_at      DateTime?
  deleted_at      DateTime?

  @@index([lesson_id])
  @@index([attachment_type])
  @@index([deleted_at])
  @@index([parent_file_id])
}

model module {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String?
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([deleted_at])
}

model topic {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String?
  course_id  String?   @db.ObjectId
  subject_id String?   @db.ObjectId
  lesson_id  String?   @db.ObjectId
  summary    String?
  thumbnail  String?
  order      Int?
  free       String?
  duration   String?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([course_id])
  @@index([lesson_id])
  @@index([deleted_at])
}

model demo_video {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  course_id  String    @db.ObjectId
  title      String?
  video_type String?
  video_url  String?
  thumbnail  String?
  order      Int?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
  created_at DateTime?
  updated_at DateTime?
  deleted_at DateTime?

  @@index([course_id])
  @@index([deleted_at])
}

model training_videos {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String?
  description String?
  category    String?
  video_type  String?
  video_url   String?
  thumbnail   String?
  created_by  String?   @db.ObjectId
  updated_by  String?   @db.ObjectId
  deleted_by  String?   @db.ObjectId
  created_at  DateTime?
  updated_at  DateTime?
  deleted_at  DateTime?

  @@index([category])
  @@index([deleted_at])
}

model vimeo_videolinks {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  lesson_file_id String    @db.ObjectId
  quality        String?
  rendition      String?
  height         Int?
  width          Int?
  type           String?
  link           String?
  fps            Int?
  size           Int?
  public_name    String?
  size_short     String?
  download_link  String?
  created_by     String?   @db.ObjectId
  updated_by     String?   @db.ObjectId
  deleted_by     String?   @db.ObjectId
  created_at     DateTime?
  updated_at     DateTime?
  deleted_at     DateTime?

  @@index([lesson_file_id])
  @@index([deleted_at])
}

// ─── Books & Library ──────────────────────────────────────────────────────────

model books {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String?
  author      String?
  description String?
  cover_image String?
  status      String?   @default("Available")
  created_by  String?   @db.ObjectId
  updated_by  String?   @db.ObjectId
  deleted_by  String?   @db.ObjectId
  created_at  DateTime?
  updated_at  DateTime?
  deleted_at  DateTime?

  @@index([status])
  @@index([deleted_at])
}

model books_chapters {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  book_id     String    @db.ObjectId
  chapter     String?
  description String?
  created_by  String?   @db.ObjectId
  updated_by  String?   @db.ObjectId
  deleted_by  String?   @db.ObjectId
  created_at  DateTime?
  updated_at  DateTime?
  deleted_at  DateTime?

  @@index([book_id])
  @@index([deleted_at])
}

// ─── Short Content ────────────────────────────────────────────────────────────

model short_videos {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  title           String?
  course_id       String?   @db.ObjectId
  thumbnail       String?
  uploaded_video  String?
  set_as_popular  Int       @default(0)
  set_as_trending Int       @default(0)
  created_by      String?   @db.ObjectId
  updated_by      String?   @db.ObjectId
  deleted_by      String?   @db.ObjectId
  created_at      DateTime?
  updated_at      DateTime?
  deleted_at      DateTime?

  @@index([course_id])
  @@index([deleted_at])
}

model stories {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String?
  course_id  String?   @db.ObjectId
  date       DateTime?
  image      String?
  status     String?
  created_by String?   @db.ObjectId
  updated_by String?   @db.ObjectId
  deleted_by String?   @db.ObjectId
