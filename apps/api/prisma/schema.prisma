  dispatch_date    DateTime?
  delivery_date    DateTime?
  delivery_address String?
  courier_name     String?
  created_by       Int?
  updated_by       Int?
  deleted_by       Int?
  created_at       DateTime?
  updated_at       DateTime?
  deleted_at       DateTime?

  @@index([student_id], map: "idx_document_request_student")
  @@index([status], map: "idx_document_request_status")
  @@index([deleted_at], map: "idx_document_request_deleted_at")
}

model circular {
  id              Int       @id @default(autoincrement())
  title           String
  content         String?
  target_audience String?   @default("all")
  status          String?   @default("draft")
  publish_date    DateTime?
  expiry_date     DateTime?
  attachment      String?
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  created_at      DateTime?
  updated_at      DateTime?
  deleted_at      DateTime?

  @@index([status], map: "idx_circular_status")
  @@index([deleted_at], map: "idx_circular_deleted_at")
}

model mentorship_session {
  id                  Int       @id @default(autoincrement())
  student_id          Int
  mentor_type         String?   @default("ai")
  topic               String?
  summary             String?
  messages_count      Int       @default(0)
  duration_minutes    Int       @default(0)
  satisfaction_rating Int?
  created_by          Int?
  updated_by          Int?
  deleted_by          Int?
  created_at          DateTime?
  updated_at          DateTime?
  deleted_at          DateTime?

  @@index([student_id], map: "idx_mentorship_session_student")
  @@index([deleted_at], map: "idx_mentorship_session_deleted_at")
}
