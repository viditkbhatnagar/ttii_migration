RewriteEngine On

# Exclude requests for existing files or directories (e.g., images, CSS, JS)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rewrite URLs to include index.php for dynamic routes
RewriteCond %{REQUEST_URI} !^/index\.php [NC]  # Skip if URL already includes index.php
RewriteCond %{REQUEST_URI} ^/app/ [NC]         # Match URLs starting with /app/
RewriteRule ^app/(.*)$ index.php/app/$1 [L]

# Route all other requests through index.php as a fallback
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L]
