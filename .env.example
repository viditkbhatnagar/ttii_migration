NODE_ENV=development

API_HOST=0.0.0.0
API_PORT=4000
APP_BASE_URL=http://localhost:4000

WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:4000/api

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ttii
MYSQL_USER=ttii
MYSQL_PASSWORD=ttii_dev_password
MYSQL_ROOT_PASSWORD=ttii_root_password
DATABASE_URL=file:./prisma/dev.db
AUTH_SESSION_TTL_SECONDS=3600
PASSWORD_RESET_TOKEN_KEY=ttii-dev-reset-token-key-change-me
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
OTP_SIGNING_KEY=ttii-dev-otp-signing-key-change-me
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=5
AUTH_OTP_REQUEST_RATE_LIMIT_MAX=5
AUTH_OTP_VERIFY_RATE_LIMIT_MAX=10

EMAIL_PROVIDER=console
EMAIL_FROM_ADDRESS=noreply@ttii.local
EMAIL_FROM_NAME=TTII
EMAIL_BREVO_API_KEY=
EMAIL_BREVO_BASE_URL=https://api.brevo.com/v3

OTP_PROVIDER=console
OTP_HTTP_ENDPOINT=
OTP_HTTP_AUTH_TOKEN=
OTP_HTTP_SENDER_ID=
OTP_HTTP_TIMEOUT_MS=5000

STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=/tmp/ttii-storage
STORAGE_LOCAL_SIGNING_KEY=ttii-dev-storage-signing-key
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

PAYMENT_PROVIDER=mock
PAYMENT_RAZORPAY_KEY_ID=
PAYMENT_RAZORPAY_KEY_SECRET=
PAYMENT_RAZORPAY_WEBHOOK_SECRET=
PAYMENT_RAZORPAY_BASE_URL=https://api.razorpay.com/v1

ZOOM_PROVIDER=zoom_sdk
ZOOM_SDK_KEY=ttii-dev-zoom-sdk-key
ZOOM_SDK_SECRET=ttii-dev-zoom-sdk-secret-change-me
ZOOM_SIGNATURE_TTL_SECONDS=7200

OPENAI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=15000
OPENAI_RETRY_MAX_ATTEMPTS=3
OPENAI_RETRY_BASE_DELAY_MS=250
